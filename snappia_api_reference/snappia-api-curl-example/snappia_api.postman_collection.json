{
  "info": {
    "name": "Snappia Medical Coding API",
    "_postman_id": "snappia-api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Submit Job",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{API_TOKEN}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "https://api.snappia.claims/api/v1/jobs",
          "protocol": "https",
          "host": ["api", "snappia", "claims"],
          "path": ["api", "v1", "jobs"]
        },
        "body": {
          "mode": "raw",
          "raw": "{ \"patient_report\": \"Patient presents with chest pain\" }"
        }
      }
    },
    {
      "name": "Get Job Status",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{API_TOKEN}}"
          }
        ],
        "url": {
          "raw": "https://api.snappia.claims/api/v1/jobs/{{JOB_ID}}"
        }
      }
    },
    {
      "name": "List Jobs",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{API_TOKEN}}"
          }
        ],
        "url": {
          "raw": "https://api.snappia.claims/api/v1/jobs"
        }
      }
    }
  ]
}
